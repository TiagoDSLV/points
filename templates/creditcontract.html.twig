{% import "components/form/fields_macros.html.twig" as fields %}

<div class="card mt-3">
  <div class="card-header">
    <h3 class="card-title">
      <i class="ti ti-coins me-2"></i>{{ __('Points pool', 'credit') }}
    </h3>
  </div>
  <div class="card-body">

    {# ---- No pool yet: show add form ---- #}
    {% if pool is null %}
      {% if canedit %}
      <form method="post" action="{{ form_url }}">
        <input type="hidden" name="contracts_id" value="{{ item.getID() }}">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">

        <div class="row">
          {{ fields.dropdownNumberField(
            'quantity',
            0,
            __('Quantity sold', 'credit'),
            {
              'min': 1,
              'max': 1000000,
              'step': 1,
              'toadd': {'0': __('Unlimited')},
            }
          ) }}

          {{ fields.dropdownYesNo(
            'overconsumption_allowed',
            -1,
            __('Allow overconsumption', 'credit'),
          ) }}

          {{ fields.dropdownNumberField(
            'low_credit_alert',
            -1,
            __('Low credit alert threshold', 'credit'),
            {
              'min': 0,
              'max': 50,
              'step': 10,
              'toadd': {'-1': __('Disabled')},
              'unit': '%',
            }
          ) }}
        </div>

        <div class="d-flex justify-content-end mt-3">
          <button type="submit" name="add" value="1" class="btn btn-primary">
            <i class="ti ti-plus me-1"></i>{{ _x('button', 'Add') }}
          </button>
        </div>
      </form>
      {% else %}
        <p class="text-muted">{{ __('No points pool configured for this contract.', 'credit') }}</p>
      {% endif %}

    {% else %}

      {# ---- Pool stats badges ---- #}
      <div class="d-flex gap-3 mb-3 flex-wrap">
        <span class="badge bg-secondary fs-6">
          {{ __('Sold', 'credit') }}: {{ pool.quantity > 0 ? pool.quantity : __('Unlimited') }}
        </span>
        <span class="badge bg-warning text-dark fs-6">
          {{ __('Consumed', 'credit') }}: {{ total_consumed }}
        </span>
        {% if remaining is not null %}
          <span class="badge bg-success fs-6">
            {{ __('Remaining', 'credit') }}: {{ remaining }}
          </span>
        {% else %}
          <span class="badge bg-info fs-6">{{ __('Unlimited', 'credit') }}</span>
        {% endif %}
      </div>

      {# ---- Edit pool form ---- #}
      {% if canedit %}
      <form method="post" action="{{ form_url }}">
        <input type="hidden" name="id" value="{{ pool.id }}">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">

        <div class="row">
          {{ fields.dropdownNumberField(
            'quantity',
            pool.quantity,
            __('Quantity sold', 'credit'),
            {
              'min': 1,
              'max': 1000000,
              'step': 1,
              'toadd': {'0': __('Unlimited')},
            }
          ) }}

          {{ fields.dropdownYesNo(
            'overconsumption_allowed',
            pool.overconsumption_allowed,
            __('Allow overconsumption', 'credit'),
          ) }}

          {{ fields.dropdownNumberField(
            'low_credit_alert',
            pool.low_credit_alert,
            __('Low credit alert threshold', 'credit'),
            {
              'min': 0,
              'max': 50,
              'step': 10,
              'toadd': {'-1': __('Disabled')},
              'unit': '%',
            }
          ) }}
        </div>

        <div class="d-flex justify-content-end mt-2 mb-3">
          <button type="submit" name="update" value="1" class="btn btn-primary btn-sm">
            <i class="ti ti-device-floppy me-1"></i>{{ __('Save') }}
          </button>
        </div>
      </form>
      {% endif %}

      {# ---- Consumption history table ---- #}
      <h5 class="mt-4">{{ __('Consumption history', 'credit') }}</h5>

      {% if consumed_entries is empty %}
        <p class="text-muted">{{ __('No consumption recorded.', 'credit') }}</p>
      {% else %}
        <table class="table table-sm table-striped table-hover">
          <thead>
            <tr>
              <th>{{ __('Ticket') }}</th>
              <th>{{ __('Task') }}</th>
              <th>{{ __('Date') }}</th>
              <th>{{ __('Technician') }}</th>
              <th>{{ __('Rate schedule', 'credit') }}</th>
              <th>{{ __('Points') }}</th>
              {% if canedit %}<th></th>{% endif %}
            </tr>
          </thead>
          <tbody>
            {% for entry in consumed_entries %}
            <tr>
              <td>{{ entry.ticket_link|raw }}</td>
              <td>{{ entry.task_link|raw }}</td>
              <td>{{ entry.date ? entry.date|date('Y-m-d H:i') : '' }}</td>
              <td>{{ entry.tech_name }}</td>
              <td>{{ entry.bareme_name }}</td>
              <td><strong>{{ entry.consumed }}</strong></td>
              {% if canedit %}
              <td>
                <form method="post" action="{{ ticket_form_url }}"
                      onsubmit="return confirm('{{ __('Confirm deletion?') }}')">
                  <input type="hidden" name="id" value="{{ entry.id }}">
                  <input type="hidden" name="purge" value="1">
                  <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">
                  <button type="submit" class="btn btn-sm btn-danger">
                    <i class="ti ti-trash"></i>
                  </button>
                </form>
              </td>
              {% endif %}
            </tr>
            {% endfor %}
          </tbody>
          <tfoot>
            <tr>
              <td colspan="5" class="text-end fw-bold">{{ __('Total') }}</td>
              <td><strong>{{ total_consumed }}</strong></td>
              {% if canedit %}<td></td>{% endif %}
            </tr>
          </tfoot>
        </table>
      {% endif %}

    {% endif %}

  </div>
</div>
