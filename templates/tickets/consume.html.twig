{% import "components/form/fields_macros.html.twig" as fields %}
{% set rand = random() %}

<div name="credit_consume_{{ rand }}">

    <div class="hr-text mt-2">
        <i class="fa-2x ti ti-coin"></i>
        <span>{{ type_name }}</span>
    </div>

    {% if pool is null %}
        <div class="alert alert-secondary mt-2">
            <i class="ti ti-info-circle me-2"></i>{{ __('No points contract linked to this ticket.', 'credit') }}
        </div>
    {% else %}

        {{ fields.sliderField(
            'plugin_credit_consumed_voucher',
            consume,
            __('Consume a voucher ?', 'credit'),
            {
                'additional_attributes': {
                    'onchange': 'showCreditDiv' ~ rand ~ '(this.value)',
                },
                'rand': rand,
            }
        ) }}

        <div id="creditvoucherblock{{ rand }}" style="display: {% if consume == 1 %}block{% else %}none{% endif %}">
            <div class="row">

                {# Contract info (read-only) #}
                <div class="col-6 col-sm-6">
                    <div class="row mb-2">
                        <label class="col-xxl-5 col-form-label">
                            {{ __('Contract', 'credit') }}
                        </label>
                        <div class="col-xxl-7 d-flex align-items-center gap-2">
                            <span class="fw-semibold">{{ pool.contract_name }}</span>
                            <span class="badge bg-secondary">
                                {% if pool.unlimited %}
                                    {{ __('Unlimited', 'credit') }}
                                {% else %}
                                    {{ pool.remaining }} pts restants
                                {% endif %}
                            </span>
                        </div>
                    </div>
                </div>

                {# Bareme dropdown #}
                <div class="col-6 col-sm-6">
                    <div class="row mb-2">
                        <label class="col-xxl-5 col-form-label">
                            {{ __('Rate scale', 'credit') }}
                        </label>
                        <div class="col-xxl-7">
                            <select id="plugin_credit_bareme_id_{{ rand }}"
                                    name="plugin_credit_bareme_id"
                                    class="form-select"
                                    onchange="onBaremeChange{{ rand }}()">
                                <option value="0">{{ __('-- Manual entry --', 'credit') }}</option>
                                {% for id, bareme in baremes %}
                                    <option value="{{ id }}" data-points="{{ bareme.points_par_tranche }}">
                                        {{ bareme.name }} ({{ bareme.points_par_tranche }} pts / 15 min)
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>

                {# Auto-calculation preview badge #}
                <div class="col-12 mb-2" id="credit_auto_calc_block_{{ rand }}" style="display:none;">
                    <div class="alert alert-info py-2 px-3 mb-0 d-flex align-items-center gap-2">
                        <i class="ti ti-calculator"></i>
                        <span>
                            {{ __('Auto-calculated points', 'credit') }} :
                            <strong id="credit_auto_calc_detail_{{ rand }}">—</strong>
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <script>
            function showCreditDiv{{ rand }}() {
                const creditVoucherBlock = document.getElementById('creditvoucherblock{{ rand }}');
                if (creditVoucherBlock) {
                    const isHidden = creditVoucherBlock.style.display !== 'none';
                    creditVoucherBlock.style.display = isHidden ? 'none' : 'block';
                }
            }

            function getTaskDurationSeconds{{ rand }}() {
                // GLPI 11 showTimestampForm() renders selects named "_actiontime_hours" /
                // "_actiontime_minutes" (leading underscore, plural). Try these first because
                // they reflect the user's current selection immediately on change.
                var hourSel   = document.querySelector('select[name="_actiontime_hours"]');
                var minuteSel = document.querySelector('select[name="_actiontime_minutes"]');
                if (hourSel && minuteSel) {
                    return (parseInt(hourSel.value) || 0) * 3600
                         + (parseInt(minuteSel.value) || 0) * 60;
                }

                // Fallback (older GLPI or after JS has synced): hidden input in seconds
                var hidden = document.querySelector('input[name="actiontime"]');
                if (hidden && parseInt(hidden.value) > 0) {
                    return parseInt(hidden.value);
                }

                return 0;
            }

            function onBaremeChange{{ rand }}() {
                var baremeSelect = document.getElementById('plugin_credit_bareme_id_{{ rand }}');
                var autoBlock    = document.getElementById('credit_auto_calc_block_{{ rand }}');
                var autoDetail   = document.getElementById('credit_auto_calc_detail_{{ rand }}');

                if (!baremeSelect) return;

                var baremeId = parseInt(baremeSelect.value) || 0;

                if (baremeId === 0) {
                    // Manual mode: hide auto-calc block
                    if (autoBlock) autoBlock.style.display = 'none';
                    return;
                }

                if (autoBlock) autoBlock.style.display = 'block';

                var durationSeconds = getTaskDurationSeconds{{ rand }}();
                if (durationSeconds <= 0) {
                    if (autoDetail) autoDetail.textContent = '{{ __('Duration not set yet', 'credit') }}';
                    return;
                }

                var durationMinutes = durationSeconds / 60;
                var tranches        = Math.ceil(durationMinutes / 15);
                var selectedOption  = baremeSelect.options[baremeSelect.selectedIndex];
                var ptsPerTranche   = parseInt(selectedOption.getAttribute('data-points')) || 0;
                var points          = tranches * ptsPerTranche;

                if (autoDetail) {
                    autoDetail.textContent = points + ' pts'
                        + ' (' + tranches + ' × ' + ptsPerTranche + ' pts)';
                }
            }

            // Defer listener attachment until after GLPI's own form JS has initialized
            // the duration picker (avoids querySelector returning null at parse time).
            requestAnimationFrame(function watchDuration{{ rand }}() {
                var targets = [
                    document.querySelector('select[name="_actiontime_hours"]'),
                    document.querySelector('select[name="_actiontime_minutes"]'),
                    document.querySelector('input[name="actiontime"]'),
                ].filter(Boolean);

                targets.forEach(function(el) {
                    el.addEventListener('change', onBaremeChange{{ rand }});
                    el.addEventListener('input',  onBaremeChange{{ rand }});
                });

                // Trigger once in case a barème is already selected when the form opens
                onBaremeChange{{ rand }}();
            });
        </script>
    {% endif %}
</div>
