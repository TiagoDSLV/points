<div class="credit_ticket_form">
    <div class="spaced">
    <div class="hr-text mt-2">
        <i class="fa-2x ti ti-coins"></i>
        <span>{{ __('Consumed credits for this ticket', 'credit') }}</span>
    </div>

    {% if remaining_points is not null %}
        <div class="alert alert-info py-2 mb-2">
            <i class="ti ti-coin me-1"></i>
            {{ __('Remaining points on contract', 'credit') }}: <strong>{{ remaining_points }}</strong>
            {% if pool_name %}
                <span class="text-muted ms-2">
                    {% if contract_url %}<a href="{{ contract_url }}" class="text-muted">{{ pool_name }}</a>{% else %}{{ pool_name }}{% endif %}
                </span>
            {% endif %}
        </div>
    {% elseif pool_unlimited %}
        <div class="alert alert-info py-2 mb-2">
            <i class="ti ti-infinity me-1"></i>
            {{ __('Unlimited points contract', 'credit') }}
            {% if pool_name %}
                <span class="text-muted ms-2">
                    {% if contract_url %}<a href="{{ contract_url }}" class="text-muted">{{ pool_name }}</a>{% else %}{{ pool_name }}{% endif %}
                </span>
            {% endif %}
        </div>
    {% elseif entries is not empty %}
        <div class="alert alert-warning py-2 mb-2">
            <i class="ti ti-alert-triangle me-1"></i>
            {{ __('No points contract linked to this ticket.', 'credit') }}
        </div>
    {% endif %}

    {% set columns = {
        'name': __('Contract', 'credit'),
        'date_creation': __('Date consumed', 'credit'),
        'users_id': __('User consumed', 'credit'),
        'task_link': __('Task', 'credit'),
        'bareme_name': __('Rate scale', 'credit'),
        'task_duration': __('Duration', 'credit'),
        'consumed': __('Quantity consumed', 'credit')
    } %}

    {% set datatable_params = {
        'is_tab': true,
        'nopager': true,
        'nofilter': true,
        'nosort': true,
        'columns': columns,
        'formatters': {
            'name': 'raw_html',
            'consumed': 'raw_html',
            'date_creation': 'datetime',
            'users_id': 'raw_html',
            'task_link': 'raw_html',
            'bareme_name': 'raw_html',
            'task_duration': 'raw_html',
        },
        'entries': entries,
        'total_number': entries|length,
        'filtered_number': entries|length,
    } %}

    {{ include('components/datatable.html.twig', datatable_params, with_context = false) }}

    {% if total_consumed > 0 %}
        <div class="text-end fw-bold mt-2">
            {{ __('Total consumed on this ticket', 'credit') }}: {{ total_consumed }} pts
        </div>
    {% endif %}
</div>
